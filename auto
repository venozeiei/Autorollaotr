local HttpService = game:GetService("HttpService")

-- ░░░░░░░░░░ ระบบโหลด Config (JSON / getgenv) ░░░░░░░░░░
local DefaultConfig = {
    TargetSlot = "A",          
    TargetFamilies = {"Helos", "Fritz", "Ackerman"}, 
    Delay = 0.5                
}

-- 1. พยายามอ่านค่าที่เคยเซฟไว้ในไฟล์
local ConfigData = {}
pcall(function()
    if isfile("Venoz_AoTR_Config.json") then
        ConfigData = HttpService:JSONDecode(readfile("Venoz_AoTR_Config.json"))
    end
end)

-- 2. อ่านค่าจาก getgenv() (ถ้ามีคนตั้งไว้ก่อนรัน loadstring)
local UserGenV = getgenv().Venoz_Config or {}

-- 3. รวมค่า (ลำดับความสำคัญ: getgenv > JSON File > Default)
_G.TargetSlot = UserGenV.TargetSlot or ConfigData.TargetSlot or DefaultConfig.TargetSlot
_G.TargetFamilies = UserGenV.TargetFamilies or ConfigData.TargetFamilies or DefaultConfig.TargetFamilies
_G.Delay = UserGenV.Delay or ConfigData.Delay or DefaultConfig.Delay
_G.AutoRoll = UserGenV.AutoRoll or false -- AutoRoll ไม่เซฟลงไฟล์เพื่อความปลอดภัย ให้กดเริ่มสุ่มเอง

-- ฟังก์ชันเซฟไฟล์ทุกครั้งที่มีการกดตั้งค่าใน UI
local function SaveConfig()
    local data = {
        TargetSlot = _G.TargetSlot,
        TargetFamilies = _G.TargetFamilies,
        Delay = _G.Delay
    }
    pcall(function()
        writefile("Venoz_AoTR_Config.json", HttpService:JSONEncode(data))
    end)
end
