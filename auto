    print("🛠️ กำลังกระชากแถบเมนูหลบปุ่ม Roblox...")
    pcall(function() topbar.Position = UDim2.new(0, 0, 0, 150) end)
    task.wait(0.5) 
    
    local topbarMain = topbar:WaitForChild("Main", 999)
    local questsTabBtn = topbarMain:WaitForChild("Categories", 999):WaitForChild("Quests", 999):WaitForChild("Interact", 999)
    
    print("📜 กำลังคลิกปุ่มเปิด Quests บน Topbar...")
    if VIM_Click(questsTabBtn) then 
        task.wait(2) 
    else 
        print("❌ หาปุ่ม Quests ไม่เจอ! วาร์ปกลับ Title")
        RejoinTitleScreen()
        return 
    end
    
    local questsUI = interface:WaitForChild("Quests")
    local questsContainer = questsUI:WaitForChild("Main"):WaitForChild("Details"):WaitForChild("Quests")
    local clicked = 0
    
    print("🎯 เริ่มสแกนเควสต์...")
    for i = 1, 100 do 
        local foundClaim = false
        for _, questFrame in pairs(questsContainer:GetChildren()) do
            if questFrame:IsA("GuiObject") then
                local claim = questFrame:FindFirstChild("Inner") and questFrame.Inner:FindFirstChild("Claim")
                if claim and claim.Visible then
                    local button = claim:FindFirstChild("Button")
                    if button and button.Visible and button.AbsolutePosition.X > 0 then
                        foundClaim = true
                        if questsContainer:IsA("ScrollingFrame") then
                            local targetY = questFrame.AbsolutePosition.Y - questsContainer.AbsolutePosition.Y + questsContainer.CanvasPosition.Y
