local function StartAutoRoll()
    task.spawn(function()
        UpdateStatus("กำลังเริ่มต้นระบบและเช็ค Gamepass...")
        setHorstDesc("Checking Gamepass & System...")
        
        if not GET then 
            return 
        end
        
        UpdateStatus("⏳ รอตัวละครโหลดเข้าแมพ...")
        while not (plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character.Parent == game.Workspace) do
            task.wait(1)
        end
        task.wait(1.5)

        local hasFamilyBag = false
        task.spawn(function()
            pcall(function() hasFamilyBag = MarketplaceService:UserOwnsGamePassAsync(plr.UserId, 268079397) end)
        end)
        task.wait(0.5)

        UpdateStatus("กำลังโหลดข้อมูลกระเป๋า (รอเซิร์ฟเวอร์เกม)...")

        local function getPriority(name)
            local upName = string.upper(name)
            local isTarget = false
            for _, target in ipairs(_G.TargetFamilies) do
                if string.find(upName, string.upper(target)) then
                    isTarget = true
                    break
                end
            end
            if not isTarget then return 9999 end
            for i, master in ipairs(MasterPriorityList) do
                if string.find(upName, string.upper(master)) then return i end
            end
            return 9999
        end

        local function getBagInfo(data, activeSlot)
            local filledCount = 0
            local fams = {}
            local maxSlots = 1 
            if hasFamilyBag then maxSlots = maxSlots + 10 end
            if data and data.Slots and data.Slots[activeSlot] then
                local extra = data.Slots[activeSlot].Extra_Slots
                if type(extra) == "number" then
                    maxSlots = maxSlots + extra
                elseif type(extra) == "table" then
                    if type(extra.Families) == "number" then
                        maxSlots = maxSlots + extra.Families
                    elseif type(extra.Family) == "number" then
                        maxSlots = maxSlots + extra.Family
                    end
                end
                local inventory = data.Slots[activeSlot].Inventory
                if inventory and type(inventory.Families) == "table" then
                    for _, famName in pairs(inventory.Families) do
                        if type(famName) == "string" and famName ~= "" and famName ~= "None" then
                            table.insert(fams, famName)
                        end
                    end
                    filledCount = #fams
                end
            end
            return maxSlots, filledCount, fams
        end

        local function getRealFamilyBagText(data, activeSlot)
            local maxSlots, filledCount, fams = getBagInfo(data, activeSlot)
            local famListText = filledCount > 0 and table.concat(fams, ", ") or "None"
            return string.format("%d/%d %s", filledCount, maxSlots, famListText)
        end

        local serverData = {}
        local initTries = 0
        while _G.AutoRoll and initTries < 10 do
            local ok, res = pcall(function() return GET:InvokeServer("Functions", "Settings", "Blur", "Off") end)
            if ok and type(res) == "table" and type(res.Slots) == "table" then
                serverData = res
                break
            end
            initTries = initTries + 1
            task.wait(1)
        end

        if not _G.AutoRoll then return end
        
        -- 🛑 ตรวจสอบช่องกระเป๋าว่าเต็มหรือยัง?
        local maxSlotsCheck = getBagInfo(serverData, _G.TargetSlot)
        if maxSlotsCheck < 6 then 
            UpdateStatus("🚀 กระเป๋ายังไม่เต็ม 6 ช่อง! วาร์ปไป Lobby...")
            setHorstDesc("Bag < 6: Bypassing to Lobby...")
            GET:InvokeServer("Functions", "Select", _G.TargetSlot)
            task.wait(1.5)
            pcall(function() GET:InvokeServer("Functions", "Teleport", "Lobby") end)
            task.wait(15)
            return
        end

        UpdateStatus("กำลังเคลียร์เผ่าที่ไม่ได้อยู่ในเป้าหมายออก...")
        local _, _, currentFams = getBagInfo(serverData, _G.TargetSlot)
        for _, fam in ipairs(currentFams) do
            if getPriority(fam) == 9999 then
                GET:InvokeServer("Family", "Delete", fam)
                task.wait(0.5)
            end
        end

        local okInit, initRes = pcall(function() return GET:InvokeServer("Functions", "Settings", "Blur", "Off") end)
        if okInit then serverData = initRes end

        local familyBagText = getRealFamilyBagText(serverData, _G.TargetSlot)
        UpdateStatus("เตรียมพร้อมสุ่ม! Bag: " .. familyBagText)

        pcall(function()
            local titleUiNode = interface:FindFirstChild("Title_Screen")
            if titleUiNode and titleUiNode.Visible then
                local playBtn = titleUiNode:FindFirstChild("Main") and titleUiNode.Main:FindFirstChild("Buttons") and titleUiNode.Main.Buttons:FindFirstChild("Play")
                if playBtn and playBtn.Visible then
                    UpdateStatus("กำลังกดปุ่ม PLAY เข้าสู่หน้า Slot อัตโนมัติ...")
                    VIM_Click(playBtn)
                    task.wait(1.5)
                end
            end
        end)

        task.spawn(function()
            while _G.AutoRoll do
                if plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = plr.Character.HumanoidRootPart
                    hrp.CFrame = hrp.CFrame * CFrame.new(0, 0.01, 0)
                    task.wait(0.1)
                    hrp.CFrame = hrp.CFrame * CFrame.new(0, -0.01, 0)
                end
                task.wait(30)
            end
        end)

        GET:InvokeServer("Functions", "Select", _G.TargetSlot)
        task.wait(1)

        local rollCount = 0
        while _G.AutoRoll do
            local results = {GET:InvokeServer("Family", "Roll")}
            local tickets = results[1]
            local familyName = results[3] or results[2]
            
            if type(tickets) == "number" and tickets <= 0 then
                UpdateStatus("🛑 ตั๋วหมด! | คลัง: " .. familyBagText)
                setHorstDesc(string.format("Fam:NO_TICKET Bag: %s", familyBagText))
                _G.AutoRoll = false 
                break
            end
            
            if type(tickets) == "number" and type(familyName) == "string" and familyName ~= "" then
                rollCount = rollCount + 1
                local prio = getPriority(familyName)
                
                if prio < 9999 then
                    UpdateStatus("✨ เจอเป้าหมาย: " .. familyName)
                    local ok2, newData = pcall(function() return GET:InvokeServer("Functions", "Settings", "Blur", "Off") end)
                    if ok2 and type(newData) == "table" then
                        local maxSlots, filledCount, currentBag = getBagInfo(newData, _G.TargetSlot)
                        if filledCount < maxSlots then
                            task.wait(1.5)
                            GET:InvokeServer("Family", "Store")
                        else
                            local worstFam = nil
                            local worstPrio = -1
                            for _, bFam in ipairs(currentBag) do
                                local bPrio = getPriority(bFam)
                                if bPrio > worstPrio then
                                    worstPrio = bPrio
                                    worstFam = bFam
                                end
                            end
                            if worstFam and prio < worstPrio then
                                task.wait(1)
                                GET:InvokeServer("Family", "Delete", worstFam)
                                task.wait(1)
                                GET:InvokeServer("Family", "Store")
                            end
                        end
                    end
                end
                
                local ok3, finalData = pcall(function() return GET:InvokeServer("Functions", "Settings", "Blur", "Off") end)
                if ok3 and type(finalData) == "table" then
                    familyBagText = getRealFamilyBagText(finalData, _G.TargetSlot)
                    UpdateStatus(string.format("Roll #%d | %s | ตั๋ว: %d | คลัง: %s", rollCount, familyName, tickets, familyBagText))
                    setHorstDesc(string.format("Fam:%s Bag: %s", familyName, familyBagText)) 
                end
            end
            
            task.wait(_G.Delay)
        end
    end)
end

